# ============================================================
# INDIAN TRADING SYSTEM - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# --- ICICI Direct Breeze API ---
# Get these from: https://api.icicidirect.com/apiuser/home
# Step 1: Log in to your ICICI Direct account
# Step 2: Go to API section, generate API key and secret
# Step 3: You'll also need your Session Token (generated daily)
ICICI_API_KEY=your_api_key_here
ICICI_API_SECRET=your_api_secret_here
ICICI_SESSION_TOKEN=your_session_token_here

# --- News API (optional, for broader news coverage) ---
# Get from: https://newsapi.org/register (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# --- Database ---
DATABASE_URL=sqlite:///data/trading.db

# --- Strategy Parameters (can be overridden in config/strategy.yaml) ---
MAX_STOCKS=15
REBALANCE_DAY=Monday
STOP_LOSS_PCT=8.0
MAX_POSITION_PCT=7.0
